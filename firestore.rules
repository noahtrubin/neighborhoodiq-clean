rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public ZIP data. Readable by anyone; only the server (Admin SDK, which
    // bypasses these rules) writes it. No client writes allowed.
    match /zips/{zip} {
      allow read: if true;
      allow write: if false;
    }

    // National model scores + meta, refreshed monthly by the Cloud Run Job.
    // The app reads these server-side via the Admin SDK (which bypasses these
    // rules), so the collections are fully closed to client access.
    match /scores/{zip} {
      allow read, write: if false;
    }
    match /meta/{doc} {
      allow read, write: if false;
    }

    // Per-user data (favorites, saved chats). Only the signed-in owner may
    // read or write their own subtree.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
