# Anthropic API key used by the /api/analyze serverless proxy.
# - Local dev (vercel dev): copy this file to .env.local and fill in the key.
# - Production: set ANTHROPIC_API_KEY in Vercel → Project → Settings → Environment Variables.
# Never commit a real key. .env.local and .env are gitignored.
ANTHROPIC_API_KEY=sk-ant-your-key-here
